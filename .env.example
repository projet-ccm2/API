PORT=3000
NODE_ENV=development

# Twitch token validation
TWITCH_CLIENT_ID=your_twitch_client_id_here
TWITCH_API_URL=https://id.twitch.tv/oauth2

# DB gateway
DB_SERVICE_URL=http://localhost:3001

# VPC auth — JWT signed locally with this secret (audience: vpc-db-gateway)
JWT_SECRET=dev-secret-change-in-production

# Rate limiting (per user_id)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# Notifications (Twitch chat + Discord) — same secrets as notification-handler
TWITCH_LISTENER_URL=http://localhost:3002
CHAT_API_KEY=your_chat_api_key_here
DISCORD_NOTIF_URL=http://localhost:3003
